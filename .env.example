# Supabase — fill in from `supabase status` (local) or your project dashboard (prod)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL for OAuth + email-link redirects (production must set this)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry (optional — leave blank in dev to disable error reporting)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
